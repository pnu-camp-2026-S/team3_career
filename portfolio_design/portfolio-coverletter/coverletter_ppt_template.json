      "competencies",
      "representativeExperience",
      "workStyle",
      "contributionPlan",
      "questionMap",
      "missingFields"
    ],
    "maxTextRules": {
      "headline": 70,
      "paragraph": 260,
      "cardBody": 95,
      "chip": 14
    },
    "hallucinationPolicy": [
      "사용자가 제공하지 않은 회사명, 성과 수치, 수상, 자격 취득 여부는 생성하지 않는다.",
      "확인되지 않은 내용은 보완 필요 정보로 남긴다.",
      "선택 경험과 마이페이지 전공을 최우선 근거로 사용한다."
    ]
  },
