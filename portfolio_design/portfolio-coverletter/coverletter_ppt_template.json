  "pptxGenJsImplementationHints": {
    "shapeMapping": {
      "rect": "slide.addShape(pptx.ShapeType.rect, options)",
      "roundRect": "slide.addShape(pptx.ShapeType.roundRect, options)",
      "ellipse": "slide.addShape(pptx.ShapeType.ellipse, options)"
    },
    "textMapping": "slide.addText(text, { x, y, w, h, fontFace, fontSize, color, bold, margin, fit })",
    "repeatCardRule": "binding 배열을 maxItems만큼 자르고, x/y와 gapX/gapY를 기준으로 카드를 반복 배치한다.",
    "tableRule": "header row는 primary 배경, body row는 white 배경과 softLine 구분선을 사용한다."
  }
